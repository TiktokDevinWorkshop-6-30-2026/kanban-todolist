# Devin service-user API key. Used by the server to authenticate requests
# to the Devin v3 API. Keep this secret — never commit your real key.
DEVIN_API_KEY=cog_your_api_key_here

# Organization (prefix: org-) that Devin sessions are created in.
# Required to enable the "Run with Devin" feature.
DEVIN_ORG_ID=org-your_org_id_here

# Email of the org member that created sessions are attributed to
# (via create_as_user_id). Required to enable the "Run with Devin" feature.
# When DEVIN_ORG_ID or DEVIN_USER_EMAIL is missing, the Devin UI is hidden.
DEVIN_USER_EMAIL=you@yourcompany.com

# Port the local server listens on (optional, defaults to 3000).
PORT=3000

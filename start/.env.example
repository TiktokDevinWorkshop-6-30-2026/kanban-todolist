# Copy this file to .env and fill in your values to enable the "Run with Devin"
# integration. Without these, the app still works fully — the Devin UI just hides.
# Never commit the real .env file.

# Devin API key (service-user key). Stays server-side; never sent to the browser.
DEVIN_API_KEY=cog_your_api_key_here

# Organization the sessions are created in.
DEVIN_ORG_ID=org-your_org_id_here

# Email of the org member that created sessions are attributed to.
DEVIN_USER_EMAIL=you@yourcompany.com

# Port the local server listens on (optional, defaults to 3000).
PORT=3000

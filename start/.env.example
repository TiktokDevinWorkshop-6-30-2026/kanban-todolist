# Copy this file to `.env` and fill in real values (never commit `.env`).
# All three are required to enable the "Run with Devin" integration;
# leave them unset and the app still works with the Devin UI hidden.

# Devin service-account API key (kept server-side only).
DEVIN_API_KEY=cog_your_api_key_here

# Organization the sessions are created in.
DEVIN_ORG_ID=org-your_org_id_here

# Email of the org member sessions are attributed to.
DEVIN_USER_EMAIL=you@yourcompany.com

# Port for the local server (optional, defaults to 3000).
PORT=3000
